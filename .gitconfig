[user]
	name = alexandros filotheou
	email = alexandros.filotheou@gmail.com

[alias]
	logtree = log --graph --all --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%cr)%C(reset) %C(white)%s%C(reset)%C(bold white)— %cn%C(reset)%C(bold yellow)%d%C(reset)' --abbrev-commit --date=relative
	st = status
	co = checkout
    
    # Staged files (changes that will go into next commit)
    ls-staged = "!git diff --staged --name-only"

    # Unstaged modified files
    ls-unstaged = "!git ls-files --modified --exclude-standard"

    # Untracked files
    ls-untracked = "!git ls-files --others --exclude-standard"

    # All changed/untracked files (staged + unstaged + untracked)
    ls-all = "!git diff --staged --name-only; git ls-files --modified --exclude-standard; git ls-files --others --exclude-standard"

[core]
	excludesfile = ~/.gitignore
	autocrlf = input
	safecrlf = false
[color]
	ui = true
[diff]
  tool = meld
	guitool = meld
[merge]
	tool = meld
[init]
	defaultBranch = master
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
